# --- Telegram ---
TELEGRAM_BOT_TOKEN=
# Preferred: comma-separated Telegram chat IDs authorized for Admin Mode
# (/open, /close, /menu, /additem, /edititem, /removeitem, /orders,
# /settings) — every ID also receives new order notifications.
# Example: ADMIN_IDS=111111111,222222222
ADMIN_IDS=
# Legacy, single-admin form — used only if ADMIN_IDS is unset. Kept for
# backward compatibility with existing deployments.
ADMIN_CHAT_ID=

# --- Supabase ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Gemini ---
GEMINI_API_KEY=
# Optional: which Gemini model to use (e.g. gemini-2.5-flash). Falls back
# to a currently-supported stable Flash model if unset — set this to
# rotate models without a code change.
GEMINI_MODEL=
# Optional: opening hours, delivery-area rules, and other business policies,
# in plain text. Given to Gemini as FAQ/business-rule context so it can
# answer accurately instead of guessing. Leave empty and Gemini will
# honestly say it doesn't have that information yet, rather than
# inventing an answer.
RESTAURANT_FAQ=

# --- App ---
# Public URL of the deployed app, used when registering the Telegram webhook
APP_BASE_URL=
