# --- Telegram ---
TELEGRAM_BOT_TOKEN=
# Chat ID authorized to run /open, /close, /menu — also receives new order notifications
ADMIN_CHAT_ID=

# --- Supabase ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Gemini ---
GEMINI_API_KEY=
# Optional: opening hours, delivery-area rules, and other business policies,
# in plain text. Given to Gemini as FAQ/business-rule context so it can
# answer accurately instead of guessing. Leave empty and Gemini will
# honestly say it doesn't have that information yet, rather than
# inventing an answer.
RESTAURANT_FAQ=

# --- App ---
# Public URL of the deployed app, used when registering the Telegram webhook
APP_BASE_URL=
